bot.run(TOKEN)@app_commands.autocomplete(item=buy_autocomplete)
async def buy_command(interaction: discord.Interaction, item: str):
    game = get_game()
    response = game.handle_command("buy", item.split())
    await send_game_response(interaction, response)


