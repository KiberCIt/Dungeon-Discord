@app_commands.guilds(discord.Object(id=GUILD_ID))
async def achievement_iii_command(interaction: discord.Interaction):
    await run_game_command(interaction, "achievement_iii")


if __name__ == "__main__":
    try:
        bot.run(TOKEN)
    except KeyboardInterrupt:
        logger.info("Bot stopped manually.")


