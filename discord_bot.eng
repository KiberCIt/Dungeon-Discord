BUY_ITEMS = [
    "potion",
    "ironsword",
    "goldsword",
    "crossbow",
    "staff",
    "bracers",
    "armor",
]

USE_ITEMS = [
    "potion",
    "healing potion",
    "stone",
    "bone_amulet",
    "ironsword",
    "goldsword",
    "crossbow",
    "staff",
    "bracers",
    "armor",
]


async def buy_autocomplete(
    interaction: discord.Interaction,
    current: str,
) -> list[app_commands.Choice[str]]:
    return [
        app_commands.Choice(name=item, value=item)
        for item in BUY_ITEMS
        if current.lower() in item.lower()
    ][:25]


async def use_autocomplete(
    interaction: discord.Interaction,
    current: str,
) -> list[app_commands.Choice[str]]:
    return [
        app_commands.Choice(name=item, value=item)
        for item in USE_ITEMS
        if current.lower() in item.lower()
    ][:25]


@bot.tree.command(name="buy", description="Buy an item from the shop")
@app_commands.guilds(discord.Object(id=GUILD_ID))
@app_commands.describe(item="Item name")
@app_commands.autocomplete(item=buy_autocomplete)
async def buy_command(interaction: discord.Interaction, item: str):
    await run_game_command(interaction, "buy", item)


