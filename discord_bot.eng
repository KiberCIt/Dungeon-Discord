import os
import logging
import discord
from discord.ext import commands
import os
import logging
import discord
from discord import app_commands
from discord.ext import commands

from game.game_session import GameSession


logging.basicConfig(
    format='%(asctime)s - %(name)s - %(levelname)s - %(message)s',
    level=logging.INFO,
)
logger = logging.getLogger(__name__)

TOKEN = os.getenv("DISCORD_BOT_TOKEN")
GUILD_ID = int(os.getenv("DISCORD_GUILD_ID", "0"))

if not TOKEN:
    raise ValueError("DISCORD_BOT_TOKEN is not set.")

if not GUILD_ID:
    raise ValueError("DISCORD_GUILD_ID is not set.")

intents = discord.Intents.default()
intents.message_content = True

bot = commands.Bot(command_prefix='/', intents=intents, help_command=None)

shared_game = None
command_mentions = {}


def get_game() -> GameSession:
    global shared_game
    if shared_game is None:
        shared_game = GameSession()
    return shared_game


def build_plain_help() -> str:
    commands_map = {
        'start': 'Start the game',
        'help': 'Show the help menu',
        'randomhero': 'Create a random hero',
        'stats': 'Show hero stats',
        'dungeon': 'Enter the dungeon',
        'fight': 'Fight the monster',
        'flee': 'Try to escape',
        'next': 'Move to the next room',
        'search': 'Search the current room',
        'shop': 'Open the shop',
        'buy': 'Buy an item',
        'use': 'Use an item',
        'achievement_i': 'Show achievement I',
        'achievement_ii': 'Show achievement II',
        'achievement_iii': 'Show achievement III',
    }

    lines = []
    for cmd, desc in commands_map.items():
        mention = command_mentions.get(cmd, f'/{cmd}')
        if cmd == 'buy':
            lines.append(f'{mention} - {desc}, example: /buy item: potion')
        elif cmd == 'use':
            lines.append(f'{mention} - {desc}, example: /use item: potion')
        else:
            lines.append(f'{mention} - {desc}')
    return '\n'.join(lines)


def replace_commands_with_mentions(text: str) -> str:
    replacements = {
        '/start': command_mentions.get('start', '/start'),
        '/help': command_mentions.get('help', '/help'),
        '/randomhero': command_mentions.get('randomhero', '/randomhero'),
        '/stats': command_mentions.get('stats', '/stats'),
        '/dungeon': command_mentions.get('dungeon', '/dungeon'),
        '/fight': command_mentions.get('fight', '/fight'),
        '/flee': command_mentions.get('flee', '/flee'),
        '/next': command_mentions.get('next', '/next'),
        '/search': command_mentions.get('search', '/search'),
        '/shop': command_mentions.get('shop', '/shop'),
        '/buy': command_mentions.get('buy', '/buy'),
        '/use': command_mentions.get('use', '/use'),
        '/achievement_i': command_mentions.get('achievement_i', '/achievement_i'),
        '/achievement_ii': command_mentions.get('achievement_ii', '/achievement_ii'),
        '/achievement_iii': command_mentions.get('achievement_iii', '/achievement_iii'),
        '/Stone_I': command_mentions.get('achievement_i', '/achievement_i'),
        '/Stone_II': command_mentions.get('achievement_ii', '/achievement_ii'),
        '/Stone_III': command_mentions.get('achievement_iii', '/achievement_iii'),
    }

    for plain, mention in sorted(replacements.items(), key=lambda x: len(x[0]), reverse=True):
        text = text.replace(plain, mention)

    return text


def normalize_response(text: str) -> str:
    if text is None:
        return "No response from the game."

    text = str(text).strip()
    if not text:
        return "No response from the game."

    return replace_commands_with_mentions(text)


async def safe_send(interaction: discord.Interaction, content: str):
    content = normalize_response(content)
    if interaction.response.is_done():
        await interaction.followup.send(content)
    else:
        await interaction.response.send_message(content)


async def run_game_command(interaction: discord.Interaction, command_name: str, *args: str):
    try:
        game = get_game()
        response = game.handle_command(command_name, *args)
        await safe_send(interaction, response)
    except Exception as e:
        logger.exception("Command failed: %s args=%s", command_name, args)
        await safe_send(interaction, f"Error: {e}")


@bot.event
async def on_ready():
    guild = discord.Object(id=GUILD_ID)
    synced = await bot.tree.sync(guild=guild)

    global command_mentions
    command_mentions = {
        cmd.name: f"</{cmd.name}:{cmd.id}>"
        for cmd in synced
    }

    logger.info("Synced %s command(s) to guild %s", len(synced), GUILD_ID)
    logger.info("Logged in as %s (%s)", bot.user, bot.user.id)


@bot.tree.error
async def on_app_command_error(interaction: discord.Interaction, error: app_commands.AppCommandError):
    logger.exception("App command error", exc_info=error)
    await safe_send(interaction, f"Command error: {error}")


@bot.tree.command(name="start", description="Start the game")
@app_commands.guilds(discord.Object(id=GUILD_ID))
async def start_command(interaction: discord.Interaction):
    await run_game_command(interaction, "start")


@bot.tree.command(name="help", description="Show the help menu")
@app_commands.guilds(discord.Object(id=GUILD_ID))
async def help_command(interaction: discord.Interaction):
    await safe_send(interaction, build_plain_help())


