@app_commands.guilds(discord.Object(id=GUILD_ID))
async def flee_command(interaction: discord.Interaction):
    await run_game_command(interaction, "flee")


@bot.tree.command(name="next", description="Move to the next room")
@app_commands.guilds(discord.Object(id=GUILD_ID))
async def next_command(interaction: discord.Interaction):
    await run_game_command(interaction, "next")


@bot.tree.command(name="search", description="Search the current room")
@app_commands.guilds(discord.Object(id=GUILD_ID))
async def search_command(interaction: discord.Interaction):
    await run_game_command(interaction, "search")


@bot.tree.command(name="shop", description="Open the shop")
@app_commands.guilds(discord.Object(id=GUILD_ID))
async def shop_command(interaction: discord.Interaction):
    await run_game_command(interaction, "shop")


BUY_ITEMS = [
    "potion",
    "ironsword",
    "goldsword",
    "crossbow",
    "staff",
    "bracers",
    "armor",
]

USE_ITEMS = [
    "potion",
    "healing potion",
    "stone",
    "bone_amulet",
    "ironsword",
    "goldsword",
    "crossbow",
    "staff",
    "bracers",
    "armor",
]


async def buy_autocomplete(
    interaction: discord.Interaction,
    current: str,
) -> list[app_commands.Choice[str]]:
    return [
        app_commands.Choice(name=item, value=item)
        for item in BUY_ITEMS
        if current.lower() in item.lower()
    ][:25]


async def use_autocomplete(
    interaction: discord.Interaction,
    current: str,
) -> list[app_commands.Choice[str]]:
    return [
        app_commands.Choice(name=item, value=item)
        for item in USE_ITEMS
        if current.lower() in item.lower()
    ][:25]


@bot.tree.command(name="buy", description="Buy an item from the shop")
@app_commands.guilds(discord.Object(id=GUILD_ID))
@app_commands.describe(item="Item name")
@app_commands.autocomplete(item=buy_autocomplete)
async def buy_command(interaction: discord.Interaction, item: str):
    await run_game_command(interaction, "buy", item)


@bot.tree.command(name="use", description="Use an item from your inventory")
@app_commands.guilds(discord.Object(id=GUILD_ID))
@app_commands.describe(item="Item name")
@app_commands.autocomplete(item=use_autocomplete)
async def use_command(interaction: discord.Interaction, item: str):
    await run_game_command(interaction, "use", item)


@bot.tree.command(name="achievement_i", description="Show achievement I")
@app_commands.guilds(discord.Object(id=GUILD_ID))
async def achievement_i_command(interaction: discord.Interaction):
    await run_game_command(interaction, "achievement_i")


